generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                               String                         @id
  email                            String                         @unique
  username                         String
  discriminator                    String
  password_hash                    String
  avatar                           String?
  avatar_hash                      String?
  avatar_animated                  Boolean                        @default(false)
  avatar_updated_at                DateTime?
  banner                           String?
  banner_hash                      String?
  banner_animated                  Boolean                        @default(false)
  banner_updated_at                DateTime?
  banner_color                     String?
  bio                              String?
  pronouns                         String?
  global_name                      String?
  status                           String                         @default("online")
  custom_status_text               String?
  custom_status_emoji              String?
  custom_status_expires_at         DateTime?
  locale                           String                         @default("fr")
  theme                            String                         @default("dark")
  font_size                        Int                            @default(14)
  compact_mode                     Boolean                        @default(false)
  show_activity                    Boolean                        @default(true)
  explicit_content_filter          Int                            @default(0)
  default_message_notifications    Int                            @default(0)
  allow_dms_from                   String                         @default("everyone")
  allow_friend_requests_from       String                         @default("everyone")
  admin_level                      Int                            @default(0)
  two_factor_enabled               Boolean                        @default(false)
  two_factor_secret                String?
  two_factor_backup_codes          String?
  verified                         Boolean                        @default(false)
  email_verify_token               String?
  password_reset_token             String?
  password_reset_expires           DateTime?
  date_of_birth                    DateTime
  flags                            Int                            @default(0)
  premium                          Boolean                        @default(false)
  premium_type                     Int                            @default(0)
  premium_since                    DateTime?
  premium_lost_at                  DateTime?
  accent_color                     String?
  stripe_customer_id               String?
  bot                              Boolean                        @default(false)
  bot_token                        String?
  bot_owner_id                     String?
  application_id                   String?
  disabled                         Boolean                        @default(false)
  banned                           Boolean                        @default(false)
  ban_reason                       String?
  banned_at                        DateTime?
  banned_by                        String?
  locked_until                     DateTime?
  login_attempts                   Int                            @default(0)
  deletion_scheduled_at            DateTime?
  show_mutual_guilds               Boolean                        @default(true)
  show_mutual_friends              Boolean                        @default(true)
  streamer_mode_enabled            Boolean                        @default(false)
  streamer_mode_auto_detect        Boolean                        @default(true)
  streamer_mode_hide_links         Boolean                        @default(true)
  streamer_mode_hide_email         Boolean                        @default(true)
  streamer_mode_hide_notes         Boolean                        @default(true)
  streamer_mode_hide_notifications Boolean                        @default(true)
  streamer_mode_hide_personal_info Boolean                        @default(true)
  streamer_mode_disable_sounds     Boolean                        @default(false)
  last_seen_at                     DateTime?
  created_at                       DateTime                       @default(now())
  updated_at                       DateTime                       @updatedAt
  admin_audit_logs                 AdminAuditLog[]
  announcements_created            Announcement[]
  bot_applications                 Application[]                  @relation("BotApp")
  applications                     Application[]
  command_permissions              ApplicationCommandPermission[] @relation("CommandPermissionUser")
  audit_logs                       AuditLog[]
  automod_executions               AutoModExecution[]
  bans_issued                      Ban[]                          @relation("BanIssuer")
  bans_received                    Ban[]                          @relation("BanTarget")
  boosts                           Boost[]
  created_followers                ChannelFollower[]              @relation("FollowerCreator")
  connected_accounts               ConnectedAccount[]
  dm_memberships                   DMChannelMember[]
  emojis_created                   Emoji[]
  featured_guilds                  FeaturedGuild[]                @relation("FeaturedBy")
  friends_received                 Friend[]                       @relation("FriendTarget")
  friends_sent                     Friend[]                       @relation("FriendUser")
  owned_guilds                     Guild[]                        @relation("GuildOwner")
  guild_members                    GuildMember[]
  role_assignments_given           GuildMemberRole[]              @relation("AssignedBy")
  GuildScheduledEventUser          GuildScheduledEventUser[]
  templates_created                GuildTemplate[]                @relation("TemplateCreator")
  invites_created                  Invite[]
  messages                         Message[]
  notifications                    Notification[]
  notification_settings            NotificationSettings[]
  oauth2_tokens                    OAuth2AccessToken[]
  oauth2_codes                     OAuth2AuthorizationCode[]
  oauth2_grants                    OAuth2Grant[]
  reactions                        Reaction[]
  read_states                      ReadState[]
  refresh_tokens                   RefreshToken[]
  reports_sent                     Report[]                       @relation("ReportReporter")
  stickers_created                 Sticker[]
  soundboard_sounds_created        SoundboardSound[]
  thread_members                   ThreadMember[]
  activities                       UserActivity[]
  user_badges                      UserBadge[]
  game_library                     UserGameLibrary[]
  note_targets                     UserNote[]                     @relation("NoteTarget")
  notes                            UserNote[]                     @relation("NoteOwner")
  user_plugin_settings             UserPluginSettings[]
  subscription                     UserSubscription?
  voice_states                     VoiceState[]
  webhooks_created                 Webhook[]

  @@unique([username, discriminator])
}

model RefreshToken {
  id           String   @id
  user_id      String
  token_hash   String
  device_info  String?
  ip_address   String?
  last_used_at DateTime @default(now())
  expires_at   DateTime
  is_revoked   Boolean  @default(false)
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Guild {
  id                            String                           @id
  name                          String
  icon                          String?
  icon_hash                     String?
  banner                        String?
  banner_hash                   String?
  splash                        String?
  description                   String?
  owner_id                      String
  verification_level            Int                              @default(0)
  default_message_notifications Int                              @default(0)
  explicit_content_filter       Int                              @default(0)
  system_channel_id             String?
  system_channel_flags          Int                              @default(0)
  welcome_enabled               Boolean                          @default(false)
  afk_channel_id                String?
  afk_timeout                   Int                              @default(300)
  preferred_locale              String                           @default("fr")
  features                      String                           @default("[]")
  vanity_url_code               String?                          @unique
  premium_tier                  Int                              @default(0)
  premium_subscription_count    Int                              @default(0)
  max_members                   Int                              @default(500000)
  invites_disabled              Boolean                          @default(false)
  discoverable                  Boolean                          @default(false)
  discovery_splash              String?
  discovery_description         String?
  primary_category_id           String?
  created_at                    DateTime                         @default(now())
  updated_at                    DateTime                         @updatedAt
  application_commands          ApplicationCommand[]             @relation("GuildAppCommands")
  audit_logs                    AuditLog[]
  automod_executions            AutoModExecution[]
  automod_rules                 AutoModRule[]
  bans                          Ban[]
  boosts                        Boost[]
  channels                      Channel[]
  emojis                        Emoji[]
  featured                      FeaturedGuild?
  forum_tags                    ForumTag[]
  primary_category              DiscoveryCategory?               @relation("PrimaryCategory", fields: [primary_category_id], references: [id])
  owner                         User                             @relation("GuildOwner", fields: [owner_id], references: [id])
  GuildAnalyticsSnapshot        GuildAnalyticsSnapshot[]
  discovery_tags                GuildDiscoveryTag[]
  members                       GuildMember[]
  member_verification           GuildMemberVerification?
  onboarding                    GuildOnboarding?
  guild_plugin_settings         GuildPluginSettings[]
  role_connection_reqs          GuildRoleConnectionRequirement[] @relation("GuildRoleConnectionReqs")
  scheduled_events              GuildScheduledEvent[]
  templates                     GuildTemplate[]
  GuildWelcomeChannel           GuildWelcomeChannel[]
  welcome_screen                GuildWelcomeScreen?
  widgets                       GuildWidget?
  invites                       Invite[]
  roles                         Role[]
  stage_instances               StageInstance[]
  stickers                      Sticker[]
  soundboard_sounds             SoundboardSound[]
  voice_states                  VoiceState[]
  webhooks                      Webhook[]
}

model GuildMember {
  guild_id                     String
  user_id                      String
  nickname                     String?
  joined_at                    DateTime          @default(now())
  premium_since                DateTime?
  deaf                         Boolean           @default(false)
  mute                         Boolean           @default(false)
  pending                      Boolean           @default(false)
  communication_disabled_until DateTime?
  user                         User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  guild                        Guild             @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  role_assignments             GuildMemberRole[]
  messages                     Message[]

  @@id([guild_id, user_id])
}

model Channel {
  id                                 String                 @id
  guild_id                           String?
  name                               String
  type                               Int                    @default(0)
  position                           Int                    @default(0)
  topic                              String?
  nsfw                               Boolean                @default(false)
  parent_id                          String?
  last_message_id                    String?
  slowmode_delay                     Int                    @default(0)
  bitrate                            Int                    @default(64000)
  user_limit                         Int                    @default(0)
  default_auto_archive_duration      Int?
  thread_metadata                    String?
  total_messages                     Int                    @default(0)
  member_count                       Int                    @default(0)
  available_tags                     String?
  default_reaction_emoji             String?
  default_thread_rate_limit_per_user Int?
  default_sort_order                 Int?
  default_forum_layout               Int?                   @default(0)
  created_at                         DateTime               @default(now())
  updated_at                         DateTime               @updatedAt
  applied_tags                       AppliedTag[]
  parent                             Channel?               @relation("ChannelParent", fields: [parent_id], references: [id])
  children                           Channel[]              @relation("ChannelParent")
  guild                              Guild?                 @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  target_followers                   ChannelFollower[]      @relation("FollowerTarget")
  source_followers                   ChannelFollower[]      @relation("FollowerSource")
  welcome_channels                   GuildWelcomeChannel[]
  invites                            Invite[]
  messages                           Message[]
  notification_settings              NotificationSettings[]
  permission_overwrites              PermissionOverwrite[]
  pins                               Pin[]
  read_states                        ReadState[]
  thread_members                     ThreadMember[]
  webhooks                           Webhook[]
}

model Message {
  id                  String       @id
  channel_id          String
  author_id           String
  content             String?
  components          String?
  type                Int          @default(0)
  flags               Int          @default(0)
  edited_at           DateTime?
  tts                 Boolean      @default(false)
  mention_everyone    Boolean      @default(false)
  pinned              Boolean      @default(false)
  reference_id        String?
  thread_id           String?
  webhook_id          String?
  application_id      String?
  sticker_ids         String?
  created_at          DateTime     @default(now())
  guildMemberGuild_id String?
  guildMemberUser_id  String?
  attachments         Attachment[]
  embeds              Embed[]
  GuildMember         GuildMember? @relation(fields: [guildMemberGuild_id, guildMemberUser_id], references: [guild_id, user_id])
  author              User         @relation(fields: [author_id], references: [id])
  channel             Channel      @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  poll                Poll?
  reactions           Reaction[]
}

model Attachment {
  id            String    @id
  message_id    String
  filename      String
  storage_path  String
  url           String
  mime_type     String
  size          Int
  width         Int?
  height        Int?
  thumbnail_url String?
  spoiler       Boolean   @default(false)
  description   String?
  created_at    DateTime  @default(now())
  deleted_at    DateTime?
  message       Message   @relation(fields: [message_id], references: [id], onDelete: Cascade)
}

model Embed {
  id         String  @id
  message_id String
  data       String
  message    Message @relation(fields: [message_id], references: [id], onDelete: Cascade)
}

model Poll {
  id                String       @id
  message_id        String       @unique
  question          String
  options           String
  duration          Int          @default(86400)
  allow_multiselect Boolean      @default(false)
  ended_at          DateTime?
  created_at        DateTime     @default(now())
  message           Message      @relation(fields: [message_id], references: [id], onDelete: Cascade)
  answers           PollAnswer[]
}

model PollAnswer {
  id         String   @id
  poll_id    String
  user_id    String
  answer_ids String
  created_at DateTime @default(now())
  poll       Poll     @relation(fields: [poll_id], references: [id], onDelete: Cascade)

  @@unique([poll_id, user_id])
}

model Reaction {
  id         String   @id
  message_id String
  user_id    String
  emoji_name String
  emoji_id   String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  message    Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@unique([message_id, user_id, emoji_name, emoji_id])
}

model Pin {
  id         String   @id
  channel_id String
  message_id String
  pinned_by  String
  pinned_at  DateTime @default(now())
  channel    Channel  @relation(fields: [channel_id], references: [id], onDelete: Cascade)

  @@unique([channel_id, message_id])
}

model ReadState {
  user_id              String
  channel_id           String
  last_read_message_id String?
  mention_count        Int     @default(0)
  channel              Channel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  user                 User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, channel_id])
}

model Role {
  id                    String                           @id
  guild_id              String
  name                  String
  color                 String?
  colors                String?                         @default("{}") // JSON: {primary_color, secondary_color, tertiary_color}
  hoist                 Boolean                          @default(false)
  position              Int                              @default(0)
  permissions           BigInt                           @default(0)
  mentionable           Boolean                          @default(false)
  icon                  String?
  unicode_emoji         String?
  managed               Boolean                          @default(false)
  tags                  String?                         @default("{}") // JSON: {bot_id, integration_id, premium_subscriber, guild_connections}
  flags                 Int                              @default(0) // Role flags (1 << 0 = in_prompt)
  created_at            DateTime                         @default(now())
  command_permissions   ApplicationCommandPermission[]   @relation("CommandPermissionRole")
  members               GuildMemberRole[]
  role_connection_reqs  GuildRoleConnectionRequirement[] @relation("RoleConnectionReqs")
  permission_overwrites PermissionOverwrite[]
  guild                 Guild                            @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model GuildMemberRole {
  guild_id    String
  user_id     String
  role_id     String
  assigned_at DateTime    @default(now())
  assigned_by String?
  assigner    User?       @relation("AssignedBy", fields: [assigned_by], references: [id])
  role        Role        @relation(fields: [role_id], references: [id], onDelete: Cascade)
  member      GuildMember @relation(fields: [guild_id, user_id], references: [guild_id, user_id], onDelete: Cascade)

  @@id([guild_id, user_id, role_id])
}

model PermissionOverwrite {
  id          String  @id
  channel_id  String
  target_id   String
  target_type String
  allow       BigInt  @default(0)
  deny        BigInt  @default(0)
  role        Role    @relation(fields: [target_id], references: [id], onDelete: Cascade)
  channel     Channel @relation(fields: [channel_id], references: [id], onDelete: Cascade)

  @@unique([channel_id, target_id, target_type])
}

model Invite {
  code            String    @id
  guild_id        String
  channel_id      String
  inviter_id      String
  uses            Int       @default(0)
  max_uses        Int       @default(0)
  max_age         Int       @default(86400)
  temporary       Boolean   @default(false)
  expires_at      DateTime?
  created_at      DateTime  @default(now())
  source          String    @default("invite")
  source_guild_id String?
  inviter         User      @relation(fields: [inviter_id], references: [id])
  channel         Channel   @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  guild           Guild     @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model Ban {
  id                     String   @id
  guild_id               String
  user_id                String
  reason                 String?
  banned_by              String
  delete_message_seconds Int      @default(0)
  created_at             DateTime @default(now())
  moderator              User     @relation("BanIssuer", fields: [banned_by], references: [id])
  user                   User     @relation("BanTarget", fields: [user_id], references: [id])
  guild                  Guild    @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@unique([guild_id, user_id])
}

model Emoji {
  id             String   @id
  guild_id       String
  name           String
  creator_id     String?
  animated       Boolean  @default(false)
  available      Boolean  @default(true)
  require_colons Boolean  @default(true)
  managed        Boolean  @default(false)
  asset          String?
  created_at     DateTime @default(now())
  creator        User?    @relation(fields: [creator_id], references: [id])
  guild          Guild    @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@unique([guild_id, name])
}

model Sticker {
  id          String   @id
  guild_id    String?
  name        String
  description String?
  tags        String?
  format_type Int      @default(1)
  asset       String?
  available   Boolean  @default(true)
  sort_value  Int      @default(0)
  creator_id  String?
  created_at  DateTime @default(now())
  creator     User?    @relation(fields: [creator_id], references: [id])
  guild       Guild?   @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model SoundboardSound {
  id         String   @id
  guild_id   String?
  name       String
  emoji      String?
  file_path  String
  mime_type  String
  volume     Float    @default(1.0)
  available  Boolean  @default(true)
  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  creator    User?    @relation(fields: [created_by], references: [id])
  guild      Guild?   @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@unique([guild_id, name])
}

model Webhook {
  id                String   @id
  guild_id          String
  channel_id        String
  name              String
  avatar            String?
  token             String
  type              Int      @default(1)
  source_guild_id   String?
  source_channel_id String?
  creator_id        String
  created_at        DateTime @default(now())
  creator           User     @relation(fields: [creator_id], references: [id])
  channel           Channel  @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  guild             Guild    @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id
  guild_id    String
  user_id     String
  action_type Int
  target_id   String?
  target_type String?
  changes     String?
  reason      String?
  options     String?
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
  guild       Guild    @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id
  user_id    String
  type       String
  data       String
  guild_id   String?
  channel_id String?
  message_id String?
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Badge {
  id               String      @id
  name             String
  description      String?
  icon             String
  type             String      @default("system")
  auto_rule        String?
  label            String      @default("")
  color            String?
  priority         Int         @default(100)
  display_type     String      @default("icon")
  background_color String?     @default("#5865F2")
  text_color       String?     @default("#ffffff")
  border_color     String?     @default("#5865F2")
  gradient_start   String?     @default("#FF73FA")
  gradient_end     String?     @default("#7367F0")
  glow             Boolean     @default(false)
  glow_color       String?     @default("#FF73FA")
  icon_position    String      @default("left")
  created_at       DateTime    @default(now())
  user_badges      UserBadge[]
}

model UserBadge {
  id          String   @id
  user_id     String
  badge_id    String
  assigned_at DateTime @default(now())
  assigned_by String?
  badge       Badge    @relation(fields: [badge_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, badge_id])
}

model SubscriptionTier {
  id              String             @id
  name            String
  price_cents     Int
  currency        String             @default("EUR")
  stripe_price_id String
  features        String
  active          Boolean            @default(true)
  created_at      DateTime           @default(now())
  subscriptions   UserSubscription[]
}

model UserSubscription {
  id                     String           @id
  user_id                String           @unique
  tier_id                String
  stripe_customer_id     String
  stripe_subscription_id String           @unique
  status                 String           @default("active")
  current_period_start   DateTime
  current_period_end     DateTime
  cancel_at_period_end   Boolean          @default(false)
  canceled_at            DateTime?
  created_at             DateTime         @default(now())
  updated_at             DateTime         @updatedAt
  tier                   SubscriptionTier @relation(fields: [tier_id], references: [id])
  user                   User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Boost {
  id         String    @id
  user_id    String
  guild_id   String
  started_at DateTime  @default(now())
  ended_at   DateTime?
  guild      Guild     @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model AutoModRule {
  id               String             @id
  guild_id         String
  name             String
  creator_id       String
  event_type       Int                @default(1)
  trigger_type     Int
  trigger_metadata String             @default("{}")
  actions          String             @default("[]")
  enabled          Boolean            @default(true)
  exempt_roles     String             @default("[]")
  exempt_channels  String             @default("[]")
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  executions       AutoModExecution[]
  guild            Guild              @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model AutoModExecution {
  id              String      @id
  rule_id         String
  guild_id        String
  user_id         String
  channel_id      String?
  content         String?
  matched_content String?
  matched_keyword String?
  action          Int
  created_at      DateTime    @default(now())
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  guild           Guild       @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  rule            AutoModRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)
}

model Report {
  id          String    @id
  reporter_id String
  target_type String
  target_id   String
  reason      String
  status      String    @default("pending")
  reviewer_id String?
  notes       String?
  created_at  DateTime  @default(now())
  resolved_at DateTime?
  reporter    User      @relation("ReportReporter", fields: [reporter_id], references: [id])
}

model DMChannel {
  id              String            @id
  type            Int               @default(1)
  name            String?
  icon            String?
  owner_id        String?
  last_message_id String?
  created_at      DateTime          @default(now())
  members         DMChannelMember[]
}

model DMChannelMember {
  channel_id           String
  user_id              String
  joined_at            DateTime  @default(now())
  last_read_message_id String?
  closed               Boolean   @default(false)
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  channel              DMChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)

  @@id([channel_id, user_id])
}

model Friend {
  id         String   @id
  user_id    String
  target_id  String
  status     Int      @default(0)
  created_at DateTime @default(now())
  target     User     @relation("FriendTarget", fields: [target_id], references: [id], onDelete: Cascade)
  user       User     @relation("FriendUser", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, target_id])
}

model Plugin {
  id                 String                @id
  name               String
  slug               String                @unique
  description        String?
  version            String
  type               String
  author             String
  icon               String?
  enabled_by_default Boolean               @default(false)
  settings_schema    String?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt
  guild_settings     GuildPluginSettings[]
  user_settings      UserPluginSettings[]
}

model UserPluginSettings {
  user_id   String
  plugin_id String
  enabled   Boolean @default(false)
  settings  String?
  plugin    Plugin  @relation(fields: [plugin_id], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, plugin_id])
}

model GuildPluginSettings {
  guild_id  String
  plugin_id String
  enabled   Boolean @default(false)
  settings  String?
  plugin    Plugin  @relation(fields: [plugin_id], references: [id], onDelete: Cascade)
  guild     Guild   @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([guild_id, plugin_id])
}

model PlatformSettings {
  key        String   @id
  value      String
  updated_by String?
  updated_at DateTime @updatedAt
}

model StripeEvent {
  id         String   @id
  event_id   String   @unique
  type       String
  processed  Boolean  @default(false)
  created_at DateTime @default(now())
}

model AdminAuditLog {
  id          String   @id
  admin_id    String
  action      String
  target_type String?
  target_id   String?
  details     String?
  ip_address  String?
  created_at  DateTime @default(now())
  admin       User     @relation(fields: [admin_id], references: [id])
}

model NotificationSettings {
  id                    String   @id
  user_id               String
  guild_id              String?
  channel_id            String?
  muted                 Boolean  @default(false)
  suppress_everyone     Boolean  @default(false)
  suppress_roles        Boolean  @default(false)
  message_notifications Int      @default(0)
  channel               Channel? @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, guild_id])
  @@unique([user_id, channel_id])
}

model Application {
  id                           String                           @id
  name                         String
  description                  String?
  icon                         String?
  owner_id                     String
  bot_id                       String?
  client_secret                String?
  redirect_uris                String?
  scopes_allowed               String?
  created_at                   DateTime                         @default(now())
  bot                          User?                            @relation("BotApp", fields: [bot_id], references: [id])
  owner                        User                             @relation(fields: [owner_id], references: [id])
  commands                     ApplicationCommand[]             @relation("AppCommands")
  ApplicationCommandPermission ApplicationCommandPermission[]
  role_connection_reqs         GuildRoleConnectionRequirement[] @relation("AppConnectionReqs")
  Interaction                  Interaction[]
  oauth2_tokens                OAuth2AccessToken[]
  oauth2_codes                 OAuth2AuthorizationCode[]
  oauth2_grants                OAuth2Grant[]
}

model ApplicationCommand {
  id                         String                         @id
  application_id             String
  guild_id                   String?
  name                       String
  description                String?
  options                    String?
  default_member_permissions String?
  dm_permission              Boolean                        @default(true)
  type                       Int                            @default(1)
  nsfw                       Boolean                        @default(false)
  version                    String?
  handler                    String?
  created_at                 DateTime                       @default(now())
  updated_at                 DateTime                       @updatedAt
  guild                      Guild?                         @relation("GuildAppCommands", fields: [guild_id], references: [id], onDelete: Cascade)
  application                Application                    @relation("AppCommands", fields: [application_id], references: [id], onDelete: Cascade)
  permissions                ApplicationCommandPermission[]

  @@unique([application_id, name])
  @@index([guild_id])
}

model ApplicationCommandPermission {
  id              String             @id
  command_id      String
  application_id  String
  guild_id        String?
  role_id         String?
  user_id         String?
  permission_type Int                @default(1)
  allow           String             @default("0")
  deny            String             @default("0")
  created_at      DateTime           @default(now())
  user            User?              @relation("CommandPermissionUser", fields: [user_id], references: [id], onDelete: Cascade)
  role            Role?              @relation("CommandPermissionRole", fields: [role_id], references: [id], onDelete: Cascade)
  application     Application        @relation(fields: [application_id], references: [id], onDelete: Cascade)
  command         ApplicationCommand @relation(fields: [command_id], references: [id], onDelete: Cascade)

  @@index([command_id])
  @@index([application_id])
  @@index([guild_id])
}

model OAuth2AuthorizationCode {
  id           String      @id
  app_id       String
  user_id      String
  code         String      @unique
  scopes       String
  redirect_uri String
  expires_at   DateTime
  used         Boolean     @default(false)
  created_at   DateTime    @default(now())
  user         User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  app          Application @relation(fields: [app_id], references: [id], onDelete: Cascade)

  @@index([app_id])
  @@index([user_id])
}

model OAuth2AccessToken {
  id                 String      @id
  app_id             String
  user_id            String
  token              String      @unique
  refresh_token_hash String?
  scopes             String
  expires_at         DateTime
  created_at         DateTime    @default(now())
  user               User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  app                Application @relation(fields: [app_id], references: [id], onDelete: Cascade)

  @@index([app_id])
  @@index([user_id])
}

model OAuth2Grant {
  id         String      @id
  app_id     String
  user_id    String
  scopes     String
  created_at DateTime    @default(now())
  user       User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  app        Application @relation(fields: [app_id], references: [id], onDelete: Cascade)

  @@unique([app_id, user_id])
}

model UserNote {
  id           String   @id
  user_id      String
  note_user_id String
  note_content String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  note_target  User     @relation("NoteTarget", fields: [note_user_id], references: [id], onDelete: Cascade)
  owner        User     @relation("NoteOwner", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, note_user_id])
}

model ConnectedAccount {
  id               String    @id
  user_id          String
  type             String
  name             String
  friend_sync      Boolean   @default(false)
  show_activity    Boolean   @default(false)
  visibility       Int       @default(0)
  access_token     String?
  refresh_token    String?
  token_expires_at DateTime?
  verified         Boolean   @default(false)
  created_at       DateTime  @default(now())
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, type])
}

model UserActivity {
  id             String   @id
  user_id        String
  activity_type  String
  application_id String?
  name           String?
  state          String?
  details        String?
  timestamps     String?
  session_id     String?
  created_at     DateTime @default(now())
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model GuildTemplate {
  id                      String   @id
  code                    String   @unique
  guild_id                String
  creator_id              String
  name                    String
  description             String?
  serialized              String
  serialized_source_guild String?
  usage_count             Int      @default(0)
  is_dirty                Boolean  @default(false)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt
  creator                 User     @relation("TemplateCreator", fields: [creator_id], references: [id], onDelete: Cascade)
  guild                   Guild    @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model GuildScheduledEvent {
  id                   String                    @id
  guild_id             String
  channel_id           String?
  creator_id           String?
  name                 String
  description          String?
  scheduled_start_time DateTime
  scheduled_end_time   DateTime?
  entity_type          Int                       @default(1)
  privacy_level        Int                       @default(2)
  recurrence_rule      String?
  entity_metadata      String?
  user_count           Int                       @default(0)
  status               Int                       @default(1)
  image                String?
  created_at           DateTime                  @default(now())
  guild                Guild                     @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  users                GuildScheduledEventUser[]
}

model GuildScheduledEventUser {
  id            String              @id
  event_id      String
  user_id       String
  subscribed_at DateTime            @default(now())
  user          User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event         GuildScheduledEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
}

model GuildWelcomeChannel {
  id             String              @id
  guild_id       String
  channel_id     String
  emoji_id       String?
  description    String
  screen_id      String?
  welcome_screen GuildWelcomeScreen? @relation("WelcomeScreenChannels", fields: [screen_id], references: [id])
  channel        Channel             @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  guild          Guild               @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@unique([guild_id, channel_id])
}

model StageInstance {
  id            String   @id
  channel_id    String   @unique
  guild_id      String
  topic         String
  privacy_level Int      @default(1)
  created_at    DateTime @default(now())
  guild         Guild    @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model VoiceState {
  id                         String    @id
  user_id                    String
  guild_id                   String?
  dm_channel_id              String?
  channel_id                 String?
  session_id                 String?
  deaf                       Boolean   @default(false)
  mute                       Boolean   @default(false)
  self_deaf                  Boolean   @default(false)
  self_mute                  Boolean   @default(false)
  self_video                 Boolean   @default(false)
  suppress                   Boolean   @default(false)
  call_status                String    @default("idle")
  request_to_speak_timestamp DateTime?
  updated_at                 DateTime  @default(now())
  user                       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  guild                      Guild?    @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@unique([guild_id, user_id])
  @@index([dm_channel_id])
}

model GuildWidget {
  guild_id   String  @id
  enabled    Boolean @default(false)
  channel_id String?
  guild      Guild   @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model ThreadMember {
  id             String   @id
  thread_id      String
  user_id        String
  join_timestamp DateTime @default(now())
  flags          Int      @default(0)
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  thread         Channel  @relation(fields: [thread_id], references: [id], onDelete: Cascade)

  @@unique([thread_id, user_id])
}

model Announcement {
  id         String    @id
  title      String
  content    String
  type       String    @default("info")
  active     Boolean   @default(true)
  created_by String
  created_at DateTime  @default(now())
  expires_at DateTime?
  creator    User      @relation(fields: [created_by], references: [id])
}

model UserGameLibrary {
  id                      String    @id
  user_id                 String
  name                    String
  icon_url                String?
  last_played_at          DateTime?
  total_play_time_minutes Int       @default(0)
  created_at              DateTime  @default(now())
  user                    User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, name])
}

model GuildAnalyticsSnapshot {
  id                   String   @id
  guild_id             String
  date                 DateTime
  member_count         Int      @default(0)
  member_joins         Int      @default(0)
  member_leaves        Int      @default(0)
  message_count        Int      @default(0)
  active_members       Int      @default(0)
  active_communicators Int      @default(0)
  voice_minutes        Int      @default(0)
  top_channels         String   @default("[]")
  hourly_messages      String   @default("[]")
  join_sources         String   @default("{}")
  created_at           DateTime @default(now())
  guild                Guild    @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@unique([guild_id, date])
}

model DataExport {
  id                  String    @id
  user_id             String
  status              String    @default("processing")
  include_attachments Boolean   @default(false)
  size_bytes          Int?
  error               String?
  expires_at          DateTime?
  created_at          DateTime  @default(now())
  completed_at        DateTime?

  @@index([user_id])
  @@index([status])
}

model ApplicationRoleConnectionMetadata {
  application_id            String
  key                       String
  name                      String
  name_localizations        String?
  description               String
  description_localizations String?
  type                      Int

  @@id([application_id, key])
}

model GuildRoleConnectionRequirement {
  guild_id       String
  role_id        String
  application_id String
  metadata_key   String
  metadata_value String
  application    Application @relation("AppConnectionReqs", fields: [application_id], references: [id], onDelete: Cascade)
  role           Role        @relation("RoleConnectionReqs", fields: [role_id], references: [id], onDelete: Cascade)
  guild          Guild       @relation("GuildRoleConnectionReqs", fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([guild_id, role_id, application_id, metadata_key])
}

model UserApplicationRoleConnection {
  user_id           String
  application_id    String
  platform_name     String?
  platform_username String?
  metadata          String?

  @@id([user_id, application_id])
}

model StatusMonitor {
  id               String        @id
  name             String
  description      String?
  type             String
  endpoint         String?
  interval_seconds Int           @default(60)
  enabled          Boolean       @default(true)
  position         Int           @default(0)
  created_at       DateTime      @default(now())
  checks           StatusCheck[]

  @@index([enabled])
}

model StatusCheck {
  id         String        @id
  monitor_id String
  status     String
  latency_ms Int?
  error      String?
  checked_at DateTime      @default(now())
  monitor    StatusMonitor @relation(fields: [monitor_id], references: [id], onDelete: Cascade)

  @@index([monitor_id])
  @@index([checked_at])
}

model StatusIncident {
  id          String                 @id
  title       String
  status      String
  impact      String
  created_by  String
  created_at  DateTime               @default(now())
  resolved_at DateTime?
  updates     StatusIncidentUpdate[]

  @@index([status])
}

model StatusIncidentUpdate {
  id          String         @id
  incident_id String
  status      String
  message     String
  created_by  String
  created_at  DateTime       @default(now())
  incident    StatusIncident @relation(fields: [incident_id], references: [id], onDelete: Cascade)

  @@index([incident_id])
}

model StatusMaintenance {
  id                    String    @id
  title                 String
  description           String?
  scheduled_start       DateTime
  scheduled_end         DateTime
  status                String    @default("scheduled")
  auto_maintenance_mode Boolean   @default(false)
  started_at            DateTime?
  completed_at          DateTime?
  created_by            String
  created_at            DateTime  @default(now())

  @@index([status])
}

model ChannelFollower {
  source_channel_id String
  target_channel_id String
  created_by_id     String
  created_at        DateTime @default(now())
  created_by        User     @relation("FollowerCreator", fields: [created_by_id], references: [id])
  target_channel    Channel  @relation("FollowerTarget", fields: [target_channel_id], references: [id], onDelete: Cascade)
  source_channel    Channel  @relation("FollowerSource", fields: [source_channel_id], references: [id], onDelete: Cascade)

  @@id([source_channel_id, target_channel_id])
  @@index([target_channel_id])
}

model ForumTag {
  id         String       @id
  guild_id   String
  channel_id String?
  name       String
  emoji_id   String?
  emoji_name String?
  moderated  Boolean      @default(false)
  available  Boolean      @default(true)
  created_at DateTime     @default(now())
  applied    AppliedTag[]
  guild      Guild        @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@unique([guild_id, name])
}

model AppliedTag {
  thread_id String
  tag_id    String
  tag       ForumTag @relation(fields: [tag_id], references: [id], onDelete: Cascade)
  thread    Channel  @relation(fields: [thread_id], references: [id], onDelete: Cascade)

  @@id([thread_id, tag_id])
}

model DiscoveryCategory {
  id          String   @id
  name        String
  description String?
  emoji       String?
  label_key   String?
  icon        String?
  position    Int      @default(0)
  created_at  DateTime @default(now())
  guilds      Guild[]  @relation("PrimaryCategory")
}

model GuildDiscoveryTag {
  id       String @id @default(cuid())
  guild_id String
  tag      String
  guild    Guild  @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@unique([guild_id, tag])
  @@index([guild_id])
}

model FeaturedGuild {
  id          String    @id
  guild_id    String    @unique
  featured_by String?
  position    Int       @default(0)
  featured_at DateTime  @default(now())
  expires_at  DateTime?
  created_at  DateTime  @default(now())
  feeder      User?     @relation("FeaturedBy", fields: [featured_by], references: [id])
  guild       Guild     @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model Interaction {
  id             String      @id
  application_id String
  type           Int
  guild_id       String?
  channel_id     String?
  user_id        String?
  token          String
  data           String?
  responded      Boolean     @default(false)
  response_type  Int?
  original_message_id String?
  created_at     DateTime    @default(now())
  application    Application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@index([application_id])
  @@index([guild_id])
  @@index([channel_id])
}

model GuildWelcomeScreen {
  id          String                @id
  guild_id    String                @unique
  description String?
  enabled     Boolean               @default(false)
  created_at  DateTime              @default(now())
  channels    GuildWelcomeChannel[] @relation("WelcomeScreenChannels")
  guild       Guild                 @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model GuildOnboarding {
  id                  String   @id
  guild_id            String   @unique
  enabled             Boolean  @default(false)
  mode                Int      @default(0)
  prompts             String
  default_channel_ids String
  created_at          DateTime @default(now())
  guild               Guild    @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model GuildMemberVerification {
  id          String   @id
  guild_id    String   @unique
  description String?
  enabled     Boolean  @default(false)
  form_fields String
  created_at  DateTime @default(now())
  guild       Guild    @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}
